# Secrets — never commit
.env
*.secret

# Python environments
.venv310/
.venv311/
.venv/
venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# macOS junk
.DS_Store
**/.DS_Store

# IDE / editor
.vscode/
.idea/
*.swp

# Build / dist
dashboard/node_modules/
dashboard/dist/
*.egg-info/
dist/
build/

# Matplotlib config
.mplconfig/

# Runtime data — regenerated at startup
data/forge.db
data/forge.db-wal
data/forge.db-shm

# Large model binaries — store in Git LFS or share separately
data/models/*.ckpt

# PyTorch Lightning training logs
lightning_logs/

# Training CSV (generated by scripts/generate_data.py)
data/forge_training_data.csv

# Demo mode stream cache
data/demo_mode_stream.jsonl
